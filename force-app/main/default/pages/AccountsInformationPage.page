<apex:page controller="AccountsInformationController">
    <apex:form id="searchForm">
        <apex:inputText value="{!searchTerm}" style="width: 300px" html-placeholder="Input at least 3 characters to perform search" />
        <apex:commandButton value="Search" action="{!searchAccounts}" rerender="resultsPanel" />
        <apex:commandLink value="Clear Search" action="{!clearSearch}" rerender="resultsPanel" />
        <br />  
        <apex:panelGrid >
            <apex:repeat value="{!alphabet}" var="alph">
                <apex:actionFunction name="alphabetSearch" action="{!alphabetSearch}" rerender="resultsPanel">
                <apex:param name="a" assignTo="{!selectedAlphabet}" value=""/>
                </apex:actionFunction> 
                </apex:repeat>
        </apex:panelGrid>
    </apex:form>
    <apex:outputPanel id="resultsPanel">
        <apex:outputText value="Total Accounts: {!accountCount}" />
        <br /><br />
        <apex:dataTable value="{!accounts}" var="acc">
            <apex:column headerValue="Account Name"> <apex:outputLink value="/{!acc.Id}">{!acc.Name}</apex:outputLink></apex:column>
            <apex:column headerValue="Email Address" value="{!acc.Email_Address__c}"/>
            <apex:column headerValue="Phone Number" value="{!acc.Phone}"/>
            <apex:column headerValue="Website"> <apex:outputLink value="{!acc.Website}" target="_blank">{!acc.Website}</apex:outputLink> </apex:column>
        </apex:dataTable>
    </apex:outputPanel>
</apex:page>
